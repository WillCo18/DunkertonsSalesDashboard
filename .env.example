# Dunkerton Sales Dashboard Environment Configuration
# Copy this file to .env and fill in your values

# Supabase Configuration
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Database URL (optional - for direct connection)
# Format: postgresql://postgres:password@db.your-project-id.supabase.co:5432/postgres
DATABASE_URL=

# Next.js Dashboard (public keys only)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
